{
  "expo": {
    "name": "Prime Fibernet",
    "slug": "prime-fibernet-unified",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "primefiber",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.primefibernet.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B3A6B"
      },
      "package": "com.primefibernet.app"
    },
    "plugins": ["expo-secure-store", "expo-notifications"],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
